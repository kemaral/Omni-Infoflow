# ──────────────────────────────────────────────
# Omni-InfoFlow Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your secrets.
# NEVER commit the real .env to Git.

# OpenAI / LLM API
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=

# Lark / Feishu Webhook
LARK_WEBHOOK_URL=

# Admin protection (optional but recommended for deployed instances)
OMNIFLOW_ADMIN_TOKEN=

# Runtime data root (optional; defaults to ./data in the project root)
OMNIFLOW_DATA_DIR=

# Notion Integration
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# DeepSeek (optional)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
