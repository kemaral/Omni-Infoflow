{
    "global": {
        "project_name": "Omni-InfoFlow",
        "log_level": "INFO"
    },
    "workflow": {
        "steps": [
            "source",
            "parser",
            "ai",
            "media",
            "dispatch"
        ],
        "optional_steps": [
            "ai",
            "media"
        ],
        "continue_on_error": [
            "media"
        ],
        "max_concurrency": 3,
        "retry_policy": {
            "default_retries": 2
        }
    },
    "plugins": {
        "sources": [
            {
                "class": "app.plugins.sources.rss.RSSPlugin",
                "enabled": false,
                "config": {
                    "feed_urls": [],
                    "fetch_timeout": 30
                }
            },
            {
                "class": "app.plugins.sources.bilibili.BilibiliHotPlugin",
                "enabled": false,
                "config": {
                    "limit": 10
                }
            }
        ],
        "parsers": [
            {
                "class": "app.plugins.parsers.html_cleaner.HTMLCleanerPlugin",
                "enabled": false,
                "config": {}
            }
        ],
        "ai": [
            {
                "class": "app.plugins.ai.llm_client.LLMClientPlugin",
                "enabled": false,
                "config": {
                    "api_base": "https://api.openai.com/v1",
                    "api_key_env": "OPENAI_API_KEY",
                    "model": "gpt-4o-mini",
                    "max_tokens": 4096
                }
            }
        ],
        "media": [
            {
                "class": "app.plugins.media.edgetts.EdgeTTSPlugin",
                "enabled": false,
                "config": {
                    "voice": "zh-CN-XiaoxiaoNeural",
                    "rate": "+0%"
                }
            }
        ],
        "dispatchers": [
            {
                "class": "app.plugins.dispatchers.telegram.TelegramDispatcher",
                "enabled": false,
                "config": {}
            },
            {
                "class": "app.plugins.dispatchers.lark.LarkDispatcher",
                "enabled": false,
                "config": {}
            },
            {
                "class": "app.plugins.dispatchers.markdown_export.MarkdownExportPlugin",
                "enabled": false,
                "config": {
                    "output_dir": "data/exports"
                }
            }
        ]
    },
    "runtime": {
        "scheduler_enabled": false,
        "schedule_cron": "0 */6 * * *",
        "timezone": "Asia/Shanghai"
    }
}